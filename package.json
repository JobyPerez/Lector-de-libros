{
  "name": "lector-de-libros",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "dev:api": "npm run dev --workspace @lector/api",
    "dev:all": "concurrently --kill-others-on-fail -n api,web,worker -c green,blue,yellow \"npm run dev:api\" \"npm run dev:web:wait-api\" \"npm run dev:worker\"",
    "dev:web": "npm run dev --workspace @lector/web",
    "dev:web:wait-api": "wait-on tcp:3000 && npm run dev:web",
    "dev:worker": "npm run dev --workspace @lector/worker",
    "typecheck": "npm run typecheck --workspaces --if-present"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "wait-on": "^8.0.3"
  },
  "engines": {
    "node": ">=20.11.0",
    "npm": ">=10.0.0"
  }
}