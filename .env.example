GITHUB_MODELS_VISION_MODEL=gpt-4.1-mini

SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=replace-with-smtp-user
SMTP_PASSWORD=replace-with-smtp-password
SMTP_FROM_ADDRESS=no-reply@example.com
