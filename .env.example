API_PORT=3000
WEB_ORIGIN=http://localhost:5173
PASSWORD_RESET_URL_BASE=http://localhost:5173/reset-password

JWT_ACCESS_SECRET=replace-with-a-long-random-string-for-access-token-signing
JWT_REFRESH_SECRET=replace-with-a-long-random-string-for-refresh-token-signing

ORACLE_USER=replace-with-oracle-user
ORACLE_PASSWORD=replace-with-oracle-password
ORACLE_CONNECT_STRING=replace-with-wallet-service-name
ORACLE_WALLET_LOCATION=./wallet
ORACLE_WALLET_PASSWORD=replace-with-wallet-password

DEEPGRAM_API_KEY=replace-with-deepgram-api-key
